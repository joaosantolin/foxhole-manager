// prisma/schema.prisma

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

// Deixe apenas o provider!
datasource db {
  provider = "postgresql"
}

/// Um depósito (bunker base / relay station / seaport) em algum ponto do mapa
model Depot {
  id           String   @id @default(cuid())
  name         String   // Nome do local (ex: "The Moors - Bunker Base")
  region       String?  // Região/hex do mapa (opcional, ex: "Deadlands")
  lastRefillAt DateTime @default(now()) // Início da contagem do refresh (3 dias)
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  items        Item[]
}

/// Um item de estoque dentro de um depósito
model Item {
  id        String   @id @default(cuid())
  name      String   // Nome do item (ex: "Rifle 7.62mm", "Bandagens Básicas")
  quantity  Int      @default(0)
  category  String?  // Categoria opcional (ex: "Armas", "Munição", "Suprimentos Médicos")
  isBoxed   Boolean  @default(false)
  depotId   String
  depot     Depot    @relation(fields: [depotId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
}

/// Tarefa do quadro Kanban (produção, logística, construção, etc.)
model Task {
  id          String       @id @default(cuid())
  title       String
  description String?
  status      TaskStatus   @default(TODO)
  priority    TaskPriority @default(MEDIUM)
  order       Int          @default(0)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}